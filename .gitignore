# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Photogrammetry dumps from bake:fetch — large (~10-15 MB), regenerable.
# Analysis JSONs (small) are committed; raw triangle dumps are not.
public/baked/*-photogrammetry.json
public/baked/*-photogrammetry.glb

# Per-variant intermediate analyses from bake:analyze:multi (regenerable).
public/baked/*-analysis-?.json
public/baked/*-osm-polygon.json
public/baked/*-solar-api.test.json

# Microsoft Building Footprints cache (~50-200 MB per quadkey, regenerable).
data/ms-footprints/

# LOD2 cadastral tiles cache (auto-downloaded from Land Vermessungsämter).
# Brandenburg/Berlin: ~200 KB-30 MB per tile, regenerable.
data/lod2-brandenburg/
data/lod2-berlin/
data/lod2-sachsen/

# LOD2 per-house cache (regenerable from tiles).
public/baked/*-lod2.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local config
.claude/
