# Copy to .env.local and fill in.

# Google AI / Gemini — used by /api/export to generate the PDF
# "Personalised note" via gemini-3.1-flash-lite (overridable with GEMINI_MODEL).
# Optional: missing key → PDF ships without page 2.
GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite


# Supabase (Dev B) — optional. K-NN runs in-memory on 1620 rows (13 KB).
# Use Supabase only if you want persistence + nice dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Tavily — used by /api/export to look up local solar incentives /
# subsidies / grants for the customer's address. Optional: missing key
# → PDF ships without the "Sources" block.
# Free tier: 1000 credits at tavily.com signup.
TAVILY_API_KEY=

# Google Maps Platform — 3D Tiles (Dev A) — public, restrict by HTTP referrer.
# Reonic refunds the cost (per the track brief).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
