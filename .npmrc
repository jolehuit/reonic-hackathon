# Hoist playwright-core to the top-level node_modules so the Dockerfile's
# `COPY --from=builder /app/node_modules/playwright-core ...` step can find it.
# Without this, pnpm's strict layout keeps playwright-core inside
# .pnpm/playwright-core@*/node_modules/playwright-core (only reachable via the
# `playwright` package's internal symlinks), which breaks our targeted Docker
# COPY.
public-hoist-pattern[]=playwright-core
